# Copy this file to .env and replace placeholder values as needed.
# .env is ignored by Git.

# Point this at the logs/ directory inside the repo (gitignored).
# On Windows use forward slashes: C:/Users/you/Desktop/.../Semesterarbeit/logs
LOG_DIR=/absolute/path/to/semesterarbeit/logs
MPLCONFIGDIR=/tmp/enhancing-mplconfig

# Required for unattended online W&B logging. Interactive users can instead run:
# uv run wandb login
WANDB_API_KEY=

# Optional W&B defaults. Hydra overrides such as logger.wandb.project=orbit-tokenizer
# take precedence when the Lightning logger passes the same setting explicitly.
WANDB_ENTITY=
WANDB_PROJECT=

# Required only when using logger=comet.yaml.
COMET_API_TOKEN=
